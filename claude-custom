cmd_list() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_list_help
        exit 0
    fi

    init_config
    ensure_jq

    local count
    count=$(jq '.deployments | length' "$CONFIG_FILE")

    if [ "$count" -eq 0 ]; then
        echo -e "${YELLOW}No deployments found${NC}"
        echo ""
        echo "Add a deployment with:"
        echo "  claude-custom add <name>"
        return
    fi

    echo "Deployed Models:"
    echo ""
    printf "  %-20s %-40s %-30s %-15s\n" "NAME" "BASE URL" "MODELS" "VERSION"
    echo "  ──────────────────── ──────────────────────────────────────── ───────────────── ─────────────"

    # Get list of deployment names
    local names=()
    while IFS= read -r name; do
        names+=("$name")
    done < <(jq -r '.deployments | keys[]' "$CONFIG_FILE")

    # For each deployment, get info and version
    for name in "${names[@]}"; do
        local base_url models_display default_model model_count
        base_url=$(jq -r ".deployments.\"$name\".base_url" "$CONFIG_FILE")

        # Check if it's a legacy or multi-model deployment
        if is_legacy_deployment "$name"; then
            # Legacy single model
            models_display=$(jq -r ".deployments.\"$name\".model" "$CONFIG_FILE")
            model_count=1
        else
            # Multi-model deployment
            default_model=$(get_deployment_default_model "$name")
            model_count=0
            models_display=""
            while IFS= read -r model; do
                if [ "$model" = "$default_model" ]; then
                    if [ -n "$models_display" ]; then
                        models_display="$models_display, $model*"
                    else
                        models_display="$model*"
                    fi
                else
                    if [ -n "$models_display" ]; then
                        models_display="$models_display, $model"
                    else
                        models_display="$model"
                    fi
                fi
                ((model_count++))
            done < <(get_deployment_models "$name")
        fi

        # Get Claude version
        local tool_name="claude-$name"
        local wrapper_path="$BIN_DIR/$tool_name"
        local version="N/A"

        if [ -f "$wrapper_path" ]; then
            version=$("$wrapper_path" --version 2>/dev/null || echo "N/A")
            # Extract just the version number if possible
            if [[ "$version" =~ [0-9]+\.[0-9]+\.[0-9]+ ]]; then
                version="${BASH_REMATCH[0]}"
            fi
        fi

        # Truncate models display if too long
        local models_truncated="${models_display:0:30}"
        if [ ${#models_display} -gt 30 ]; then
            models_truncated="${models_truncated}..."
        fi

        printf "  %-20s %-40s %-30s %-15s\n" "$name" "${base_url:0:40}" "$models_truncated ($model_count)" "$version"
    done

    echo ""
    echo "  * = default model"
    echo ""
    echo "Total: $count deployment(s)"
    echo ""
    echo "Manage models with:"
    echo "  claude-custom models <name>"
}

cmd_models() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_models_help
        exit 0
    fi

    local tool_name=""
    local set_default=""
    local add_model=""
    local remove_model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --default)
                set_default="$2"
                shift 2
                ;;
            --add)
                add_model="$2"
                shift 2
                ;;
            --remove)
                remove_model="$2"
                shift 2
                ;;
            *)
                if [ -z "$tool_name" ]; then
                    tool_name="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}"
                    exit 2
                fi
                shift
                ;;
        esac
    done

    if [ -z "$tool_name" ]; then
        echo -e "${RED}Error: Tool name is required${NC}"
        echo "Usage: claude-custom models <name> [action]"
        exit 2
    fi

    init_config
    ensure_jq

    # Normalize tool name
    tool_name=$(normalize_tool_name "$tool_name")
    local basename
    basename=$(get_tool_basename "$tool_name")

    # Check if deployment exists
    if ! deployment_exists "$basename"; then
        echo -e "${RED}Error: Deployment '$tool_name' not found${NC}"
        echo ""
        echo "Run 'claude-custom list' to see available deployments"
        exit 1
    fi

    # Check if this is a legacy deployment and migrate if needed
    if is_legacy_deployment "$basename"; then
        echo "Migrating deployment to multi-model format..."
        if ! migrate_deployment_to_multi "$basename"; then
            echo -e "${RED}Error: Failed to migrate deployment${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ Migrated to multi-model format${NC}"
        echo ""
    fi

    # Handle actions
    if [ -n "$set_default" ]; then
        # Set default model
        # Check if model exists
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$set_default" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$set_default' not found in deployment${NC}"
            echo ""
            echo "Available models:"
            while IFS= read -r model; do
                echo "  - $model"
            done < <(get_deployment_models "$basename")
            exit 1
        fi

        # Update default model
        if ! jq --arg name "$basename" --arg default "$set_default" \
            '.deployments[$name].default_model = $default' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi

        # Update wrapper script with new default
        local api_key base_url
        api_key=$(jq -r ".deployments.\"$basename\".api_key" "$CONFIG_FILE")
        base_url=$(jq -r ".deployments.\"$basename\".base_url" "$CONFIG_FILE")
        write_wrapper_script "$tool_name" "$api_key" "$base_url" "$set_default"

        echo -e "${GREEN}✓ Set default model to '$set_default'${NC}"
    fi

    if [ -n "$add_model" ]; then
        # Add model to the list
        # Check if model already exists
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$add_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = true ]; then
            echo -e "${YELLOW}Warning: Model '$add_model' already exists${NC}"
        else
            # Add model to the array
            if ! jq --arg name "$basename" --arg model "$add_model" \
                '.deployments[$name].models += [$model]' \
                "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
                echo -e "${RED}Error: Failed to update config file${NC}" >&2
                rm -f "$CONFIG_FILE.tmp"
                exit 1
            fi
            echo -e "${GREEN}✓ Added model '$add_model'${NC}"
        fi
    fi

    if [ -n "$remove_model" ]; then
        # Remove model from the list
        local model_exists=false
        while IFS= read -r model; do
            if [ "$model" = "$remove_model" ]; then
                model_exists=true
                break
            fi
        done < <(get_deployment_models "$basename")

        if [ "$model_exists" = false ]; then
            echo -e "${RED}Error: Model '$remove_model' not found in deployment${NC}"
            exit 1
        fi

        # Check if it's the only model
        local model_count
        model_count=$(get_deployment_models "$basename" | wc -l | xargs)
        if [ "$model_count" -eq 1 ]; then
            echo -e "${RED}Error: Cannot remove the only model${NC}"
            echo "Use 'claude-custom update $basename --model <new-model>' to replace it"
            exit 1
        fi

        # Check if it's the default model
        local default_model
        default_model=$(get_deployment_default_model "$basename")
        if [ "$remove_model" = "$default_model" ]; then
            echo -e "${RED}Error: Cannot remove the default model${NC}"
            echo "Set a different default first with:"
            echo "  claude-custom models $basename --default <model>"
            exit 1
        fi

        # Remove model from the array
        if ! jq --arg name "$basename" --arg model "$remove_model" \
            '.deployments[$name].models |= map(select(. != $model))' \
            "$CONFIG_FILE" > "$CONFIG_FILE.tmp"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        if ! mv "$CONFIG_FILE.tmp" "$CONFIG_FILE"; then
            echo -e "${RED}Error: Failed to update config file${NC}" >&2
            rm -f "$CONFIG_FILE.tmp"
            exit 1
        fi
        echo -e "${GREEN}✓ Removed model '$remove_model'${NC}"
    fi

    # If no action specified, just list models
    if [ -z "$set_default" ] && [ -z "$add_model" ] && [ -z "$remove_model" ]; then
        local default_model
        default_model=$(get_deployment_default_model "$basename")

        echo "Models for $tool_name:"
        echo ""

        local count=0
        while IFS= read -r model; do
            if [ "$model" = "$default_model" ]; then
                echo -e "  * $model ${GREEN}(default)${NC}"
            else
                echo "    $model"
            fi
            ((count++))
        done < <(get_deployment_models "$basename")

        echo ""
        echo "Total: $count model(s)"
        echo ""
        echo "Use with:"
        echo "  $tool_name --use-model <model> <args>"
        echo "  $tool_name -m <model> <args>"
        echo "  $tool_name --use-model  # Show available models"
        echo "  $tool_name --help       # Show usage information"
        echo ""
        echo "Manage models:"
        echo "  claude-custom models $basename --default <name>"
        echo "  claude-custom models $basename --add <name>"
        echo "  claude-custom models $basename --remove <name>"
    fi
}

cmd_update() {
    # Check for help flag
    if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
        show_update_help
        exit 0
    fi

    local tool_name=""
    local new_api_key=""
    local new_base_url=""
    local new_model=""
    local add_model=""
    local remove_model=""
    local default_model=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
